@using X.PagedList.Mvc.Core
@model X.PagedList.IPagedList<Song>

@foreach(var song in Model) {
    <div class="col gallery-item" data-id="@song.Id">
        <div class="card h-100">
            <img src="@Url.Action("CoverIcon", song)" class="card-img-top" alt="@song.Title" style="height: 200px; object-fit: cover;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title mb-0">@song.Title</h5>
                    <div class="d-flex align-items-center gap-1 text-muted">
                        <i class="bi bi-heart-fill text-danger" style="font-size: 0.9rem;"></i>
                        <span class="fw-semibold small">@song.Likes</span>
                        <span class="small text-secondary">likes</span>
                    </div>
                </div>
                <h6 class="card-subtitle mb-2 text-muted">@song.Artist</h6>
                <p class="card-text">
                    <small class="text-muted">Album: @song.Album</small><br>
                    <small class="text-muted">Genre: @song.Genre</small><br>
                    <small class="text-muted">Lirycs: 
                        <a href="#" data-bs-toggle="modal" data-bs-target="#lyricsModal@(song.Id)">View</a>
                    </small>
                </p>
                <midi-player class="mt-2 w-100" src="@Url.Action("GenerateAudio", new { id = song.Id, seed = ViewBag.CurrentSeed })"></midi-player>
            </div>
        </div>
    </div>
    <div class="modal fade" id="lyricsModal@(song.Id)" tabindex="-1">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@song.Title - @song.Artist</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body small">
                    @foreach(var lyric in song.Lyrics) {
                        <p class="text-secondary mb-2" style="white-space: pre-wrap;">@lyric</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

